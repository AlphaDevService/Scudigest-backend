# Scudigest Backend — modello variabili d'ambiente
# Copia in .env.local (sviluppo) o .env (docker compose locale).
# Su Coolify: imposta le stesse chiavi nel pannello Environment Variables.
# NON committare file con valori reali.

# ─── Database Postgres ───────────────────────────────────────────────────────
DB_PASSWORD=cambia_con_password_robusta

# ─── Directus ────────────────────────────────────────────────────────────────
# Chiave segreta interna (genera un UUID)
DIRECTUS_SECRET=00000000-0000-0000-0000-000000000000

# Admin creato al PRIMO avvio su database vuoto (login su /admin)
ADMIN_EMAIL=admin@scudigest.it
ADMIN_PASSWORD=cambia_con_password_robusta

# URL pubblico di Directus (deve coincidere col dominio Coolify/produzione)
# Locale: http://localhost:8055
PUBLIC_URL=http://localhost:8055

# ─── AWS S3 (storage file Directus — obbligatorio nel compose attuale) ─────
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET=directus-bucket-scudigest
AWS_S3_REGION=eu-west-1

# ─── Opzionale: CORS (se aggiungi CORS_ORIGIN al docker-compose.yml) ─────────
# CORS_ORIGIN=http://localhost:3000,https://app.tuodominio.it
